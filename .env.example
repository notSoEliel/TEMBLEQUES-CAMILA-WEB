# Tembleques Camila - plantilla compartible de entorno local
# Copia este archivo como .env en la raiz del repo o toma sus bloques para frontend/.env y backend/.env.
# No pongas secretos reales en este archivo ni lo compartas con valores sk_, whsec_ o mongodb+srv reales.

# MongoDB
# Docker Compose usa el host "mongodb"; si corres backend fuera de Docker usa localhost.
MONGO_URI=mongodb://mongodb:27017/tembleques_camila
# MONGO_URI=mongodb://localhost:27017/tembleques_camila
# MONGO_URI=mongodb+srv://usuario:password@cluster.mongodb.net/tembleques_camila

# Clerk (https://dashboard.clerk.com → API Keys)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key
# Clerk webhook secret local (Clerk Dashboard → Webhooks → Signing Secret)
CLERK_WEBHOOK_SECRET=whsec_your_clerk_webhook_secret

# Stripe (test keys — no se cobra dinero real con claves sk_test_)
# MODO DEMO: si dejas el valor "sk_test_placeholder", el backend simula el pago
#            automáticamente sin contactar Stripe y redirige a /confirmation.
# MODO REAL: reemplaza con tu clave real de https://dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_test_placeholder
# Para obtener el webhook secret en local (recomendado):
#   brew install stripe/stripe-cli/stripe && stripe login
#   stripe listen --forward-to localhost:3000/api/stripe/webhook
#   → Copia el whsec_... que imprime aquí abajo
STRIPE_WEBHOOK_SECRET=whsec_placeholder

# Frontend
VITE_API_URL=http://localhost:3000
VITE_PROXY_TARGET=http://localhost:3000
VITE_CLOUDINARY_CLOUD_NAME=dfshkpehf
VITE_CLOUDINARY_UPLOAD_PRESET=TemblequesCamila

# Backend
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# MCP local (tokens demo aceptados por el middleware del backend)
MCP_BACKEND_URL=http://localhost:3000
MCP_ADMIN_TOKEN=mock-admin-token
MCP_CLIENT_TOKEN=mock-client-token

# E2E local opcional
E2E_MONGO_URI=mongodb://localhost:27017/tembleques_camila_e2e
E2E_STRIPE_SECRET_KEY=sk_test_placeholder
E2E_STRIPE_WEBHOOK_SECRET=whsec_placeholder
